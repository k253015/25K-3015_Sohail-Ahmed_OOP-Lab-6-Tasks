class Employee {
    void work() {
        System.out.println("Employee is working...");
    }
}

class Manager extends Employee {
    void manageTeam() {
        System.out.println("Manager is managing the team.");
    }
}

public class Main {
    public static void main(String[] args) {
        Manager myManager = new Manager();
        myManager.work();
        myManager.manageTeam();
    }
}
