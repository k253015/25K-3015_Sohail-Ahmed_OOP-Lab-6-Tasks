class Account {
    double balance = 10000.0;
}

class SavingsAccount extends Account {
}

class PremiumSavings extends SavingsAccount {
    void calculateInterest() {
        double interest = balance * 0.07;
        int intInterest = (int) interest;
        System.out.println("Balance: " + balance);
        System.out.println("Interest (as integer): " + intInterest);
    }
}

public class BankTest {
    public static void main(String[] args) {
        PremiumSavings ps = new PremiumSavings();
        ps.calculateInterest();
    }
}
